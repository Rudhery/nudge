# =====================================================================
# Nudge - example configuration
# Copy this file to ".env" and fill in your own values.
# NEVER commit your real .env - it is git-ignored.
# =====================================================================

# ---- App API ----
# Port the backend API listens on
API_PORT=8080
# Shared secret the app uses to talk to the API (generate a long random string)
API_KEY=change-me

# ---- Database ----
# Path to the local SQLite database file
DATABASE_PATH=./data/nudge.db

# ---- Reminders / WhatsApp (whatsmeow) ----
# Base URL of your self-hosted whatsmeow send endpoint
WHATSAPP_API_URL=https://your-whatsmeow-host.example.com
# Auth token for that endpoint (if it requires one)
WHATSAPP_API_TOKEN=
# Your own number in E.164 without "+" (e.g. 5511999998888)
REMINDER_RECIPIENT=

# ---- Localization ----
# IANA timezone used to schedule reminders
TIMEZONE=America/Sao_Paulo

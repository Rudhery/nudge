# Frontend configuration (Vite). Copy to ".env.local" to override locally.
# Only variables prefixed with VITE_ are exposed to the app.

# Base URL of the API. Leave empty to use the same origin:
#  - dev: Vite proxies /api to http://localhost:8080 (see vite.config.ts)
#  - prod: the Go server serves the app and the API together
VITE_API_URL=

# Bearer token — only needed if the backend has API_KEY set.
VITE_API_KEY=
